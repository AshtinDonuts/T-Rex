# hpcfs (University of Adelaide HPC) cluster environment.
# Copy to cluster.env and verify every path before running.
#
#   cd cluster/hpcfs
#   cp cluster.env.example cluster.env
#   $EDITOR cluster.env

# --- Project ---
PROJECT_ROOT=/hpcfs/users/a1865590/RoCoIROS26/T-Rex

# --- Conda ---
# CONDA_ENV can be a name (if it lives in the default envs dir) or an absolute path.
CONDA_ENV=trex

# --- Hugging Face cache ---
HF_HOME=/hpcfs/users/a1865590/.cache/huggingface

# --- Dataset paths ---
PUBLIC_DATASET_SOURCE=zekaiwang/trex_dataset
PUBLIC_DATASET_CACHE=/hpcfs/users/a1865590/scratch/trex_public_cache
PICKUP_DATASET_ROOT=/hpcfs/users/a1865590/scratch/trex_pickup_64
SMOKE_DATASET_ROOT=/hpcfs/users/a1865590/scratch/trex_pickup_smoke_4
PICKUP_MANIFEST_DIR=/hpcfs/users/a1865590/scratch/trex_pickup_manifests

# --- Model checkpoints ---
ORIGIN_MODEL_PATH=/hpcfs/users/a1865590/scratch/checkpoints/Qwen3-VL-2B-Instruct
MIDTRAIN_CHECKPOINT=/hpcfs/users/a1865590/scratch/checkpoints/T-Rex_midtrain

# --- Output ---
OUTPUT_ROOT=/hpcfs/users/a1865590/scratch/trex_pickup_runs

# --- Training knobs ---
GPUS_PER_NODE=4
USE_FLARE=1
MAX_DOWNLOAD_GB=300
WANDB_MODE=offline

# Set to 1 only after reviewing selection.json and its estimated_download_gb.
CONFIRM_DOWNLOAD=0

# --- Local comparison (fill in after copying a checkpoint back from the cluster) ---
FINETUNED_CHECKPOINT=/path/to/copied/fine-tuned-checkpoint
COMPARISON_DIR=/tmp/trex_pickup_comparison
