# Copy to cluster.env and edit every path for the cluster.
PROJECT_ROOT=/path/to/T-Rex
CONDA_SH=/path/to/miniconda3/etc/profile.d/conda.sh
CONDA_ENV=/path/to/miniconda3/envs/trex

HF_HOME=/scratch/$USER/huggingface
PUBLIC_DATASET_SOURCE=zekaiwang/trex_dataset
PUBLIC_DATASET_CACHE=/scratch/$USER/trex_public_cache
PICKUP_DATASET_ROOT=/scratch/$USER/trex_pickup_64
SMOKE_DATASET_ROOT=/scratch/$USER/trex_pickup_smoke_4

ORIGIN_MODEL_PATH=/scratch/$USER/checkpoints/Qwen3-VL-2B-Instruct
MIDTRAIN_CHECKPOINT=/scratch/$USER/checkpoints/T-Rex_midtrain
OUTPUT_ROOT=/scratch/$USER/trex_pickup_runs
PICKUP_MANIFEST_DIR=/scratch/$USER/trex_pickup_manifests

GPUS_PER_NODE=4
USE_FLARE=1
MAX_DOWNLOAD_GB=300
WANDB_MODE=offline

# Set to 1 only after reviewing selection.json and its estimated_download_gb.
CONFIRM_DOWNLOAD=0

# Local comparison paths (used by compare_local.sh after copying checkpoints back).
FINETUNED_CHECKPOINT=/path/to/copied/fine-tuned-checkpoint
COMPARISON_DIR=/tmp/trex_pickup_comparison
